{
  "name": "zodiac-rush",
  "private": true,
  "version": "0.1.0",
  "description": "조디악 러쉬 (ZODIAC RUSH) — 12지신이 달리는 3D MOBA",
  "author": "asilism",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev-online.mjs",
    "dev:web": "vite",
    "server": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "test": "node --test",
    "app": "vite build && electron .",
    "app:dev": "electron . --dev-url=http://localhost:5173",
    "app:icon": "electron scripts/render-icon.cjs",
    "app:pack": "vite build && electron-builder --win",
    "apk": "vite build && cap sync android && cd android && gradlew assembleDebug",
    "apk:release": "vite build && cap sync android && cd android && gradlew assembleRelease",
    "aab": "vite build && cap sync android && cd android && gradlew bundleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.184.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "vite": "^5.4.11"
  }
}
