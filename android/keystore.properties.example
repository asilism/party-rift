# 릴리즈 서명 키 설정 — 이 파일을 keystore.properties로 복사해 채운다.
#  keystore.properties와 *.keystore/*.jks는 절대 커밋하지 말 것(.gitignore에 등록됨).
#
# 키스토어 만들기(최초 1회):
#   keytool -genkeypair -v -keystore zodiac-release.keystore -alias zodiacblitz \
#     -keyalg RSA -keysize 2048 -validity 10000
#   (keytool은 JDK bin에 있음. 예: D:/DEV/android-tools/jdk-21.0.11+10/bin/keytool)
#
# storeFile은 android/ 폴더 기준 상대 경로 또는 절대 경로.
storeFile=zodiac-release.keystore
storePassword=바꿔주세요
keyAlias=zodiacblitz
keyPassword=바꿔주세요
